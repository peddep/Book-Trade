# Copy this file to .env.local and fill in your real values.

# Turso database connection (get these from the Turso dashboard / CLI)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Secret used to sign login session cookies. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: raises the Google Books quota for Thai title suggestions.
# Works without it; add one from https://console.cloud.google.com if Thai
# suggestions ever stop appearing due to quota.
# GOOGLE_BOOKS_API_KEY=your-key-here
